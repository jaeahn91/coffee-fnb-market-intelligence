#!/usr/bin/env bash
# Auto-fire the data harness before every commit.
#
# Git hooks live in .git/hooks/ (not version-controlled), so this tracked copy
# is the source of truth. Install it on a fresh clone with:
#   Unix:    ln -sf ../../scripts/hooks/pre-commit .git/hooks/pre-commit
#   Windows: cp scripts/hooks/pre-commit .git/hooks/pre-commit   (symlinks unreliable)
#
# Bypass intentionally (rarely) with:  git commit --no-verify
set -e

# Locate the project venv python across platforms, else fall back to system python.
if [ -f ".venv/Scripts/python.exe" ]; then   # Windows
  PY=".venv/Scripts/python.exe"
elif [ -x ".venv/bin/python" ]; then          # Unix
  PY=".venv/bin/python"
elif command -v python3 >/dev/null 2>&1; then
  PY="python3"
else
  PY="python"
fi

echo "[pre-commit] Tier 1 — data integrity..."
"$PY" scripts/validate_data.py

echo "[pre-commit] Tier 2 — golden figures..."
"$PY" scripts/check_figures.py

echo "[pre-commit] harness clean."
